{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes.local/schemas/playwright-artifact-manifest.schema.json",
  "title": "Hermes verified Playwright browser artifact manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "playwright_package",
    "playwright_package_version",
    "playwright_wheel_filename",
    "playwright_wheel_size",
    "playwright_wheel_sha256",
    "browser_family",
    "browser_revision",
    "platform",
    "archive_filename",
    "archive_size",
    "archive_sha256",
    "archive_format",
    "archive_root",
    "cache_root",
    "expected_executable_relative_path",
    "source_kind",
    "source_reference"
  ],
  "properties": {
    "manifest_version": {
      "const": 2
    },
    "playwright_package": {
      "const": "playwright"
    },
    "playwright_package_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[A-Za-z0-9.-]+)?$"
    },
    "playwright_wheel_filename": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,255}\\.whl$"
    },
    "playwright_wheel_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 134217728
    },
    "playwright_wheel_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "browser_family": {
      "const": "chromium-headless-shell"
    },
    "browser_revision": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "platform": {
      "enum": ["linux/amd64", "linux/arm64"]
    },
    "archive_filename": {
      "const": "browser-archive"
    },
    "archive_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483648
    },
    "archive_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "archive_format": {
      "enum": ["zip", "tar.gz"]
    },
    "archive_root": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,127}$"
    },
    "cache_root": {
      "const": "/opt/hermes/.playwright"
    },
    "expected_executable_relative_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9._/-]+$"
    },
    "source_kind": {
      "const": "operator-approved-offline-artifact"
    },
    "source_reference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "not": {
        "pattern": "[Ll][Aa][Tt][Ee][Ss][Tt]"
      }
    }
  }
}
